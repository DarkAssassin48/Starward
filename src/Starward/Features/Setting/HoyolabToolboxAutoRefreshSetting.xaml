<?xml version="1.0" encoding="utf-8" ?>
<sf:PageBase x:Class="Starward.Features.Setting.HoyolabToolboxAutoRefreshSetting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sf="using:Starward.Frameworks"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="820" Padding="0,0,24,24" HorizontalAlignment="Stretch" Spacing="16">

            <TextBlock FontSize="28"
                       FontWeight="SemiBold"
                       Text="{x:Bind PageTitle}"
                       TextWrapping="Wrap" />
            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind PageDescription}"
                       TextWrapping="Wrap" />

            <!-- Genshin Impact -->
            <Border Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Genshin Impact" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind GenshinDescription}"
                               TextWrapping="Wrap" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ComboBox_Genshin"
                                  Height="36"
                                  Width="320"
                                  HorizontalAlignment="Left"
                                  Padding="18.5,0,0,0"
                                  BorderThickness="0"
                                  CornerRadius="8,18,18,8"
                                  DisplayMemberPath="Name"
                                  ItemsSource="{x:Bind ScheduleOptions}" />
                        <Button Grid.Column="2"
                                MinWidth="140"
                                Tag="hk4e"
                                Click="RefreshGame_Click"
                                Content="{x:Bind RefreshNowText}" />
                    </Grid>
                    <TextBlock x:Name="TextBlock_GenshinLastRefresh"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Honkai: Star Rail -->
            <Border Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Honkai: Star Rail" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind StarRailDescription}"
                               TextWrapping="Wrap" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ComboBox_StarRail"
                                  Height="36"
                                  Width="320"
                                  HorizontalAlignment="Left"
                                  Padding="18.5,0,0,0"
                                  BorderThickness="0"
                                  CornerRadius="8,18,18,8"
                                  DisplayMemberPath="Name"
                                  ItemsSource="{x:Bind ScheduleOptions}" />
                        <Button Grid.Column="2"
                                MinWidth="140"
                                Tag="hkrpg"
                                Click="RefreshGame_Click"
                                Content="{x:Bind RefreshNowText}" />
                    </Grid>
                    <TextBlock x:Name="TextBlock_StarRailLastRefresh"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Zenless Zone Zero -->
            <Border Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Zenless Zone Zero" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind ZZZDescription}"
                               TextWrapping="Wrap" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ComboBox_ZZZ"
                                  Height="36"
                                  Width="320"
                                  HorizontalAlignment="Left"
                                  Padding="18.5,0,0,0"
                                  BorderThickness="0"
                                  CornerRadius="8,18,18,8"
                                  DisplayMemberPath="Name"
                                  ItemsSource="{x:Bind ScheduleOptions}" />
                        <Button Grid.Column="2"
                                MinWidth="140"
                                Tag="nap"
                                Click="RefreshGame_Click"
                                Content="{x:Bind RefreshNowText}" />
                    </Grid>
                    <TextBlock x:Name="TextBlock_ZZZLastRefresh"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button Click="Save_Click"
                        MinWidth="120"
                        Content="{x:Bind SaveText}"
                        Style="{ThemeResource AccentButtonStyle}" />
                <Button Grid.Column="1"
                        HorizontalAlignment="Left"
                        Click="RefreshAll_Click"
                        Content="{x:Bind RefreshAllText}" />
            </Grid>

            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind ScheduleNote}"
                       TextWrapping="Wrap" />

        </StackPanel>
    </ScrollViewer>

</sf:PageBase>
